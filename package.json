{
  "name": "bleterm",
  "version": "0.1.0",
  "description": "BLETerm - Windows desktop AT command terminal for BLE UART devices",
  "main": "electron/main.cjs",
  "author": "BLETerm",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "build": "tsc --noEmit && vite build",
    "start": "electron .",
    "dist": "npm run build && npm run dist:existing",
    "dist:existing": "powershell -NoProfile -ExecutionPolicy Bypass -File build/installer/create-from-unpacked.ps1",
    "test": "vitest run"
  },
  "dependencies": {
    "@xterm/xterm": "^5.5.0",
    "axios": "^1.7.9",
    "electron-log": "^5.2.4",
    "electron-store": "^10.0.1",
    "lucide-react": "^0.468.0",
    "node-cron": "^3.0.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^2.1.8",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.bleterm.app",
    "productName": "BLETerm",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
